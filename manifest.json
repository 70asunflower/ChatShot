{
  "manifest_version": 3,
  "name": "ChatShot",
  "version": "1.2.0",
  "description": "Capture AI chat responses as screenshots and stitch them for easy sharing",
  "permissions": ["activeTab", "clipboardWrite"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://notebooklm.google.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://www.doubao.com/*",
        "https://www.kimi.com/*",
        "https://www.qianwen.com/*",
        "https://chatglm.cn/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": ["lib/html-to-image.js", "content.js"],
      "css": ["content.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["logos/*.png", "lib/katex.min.js", "lib/katex.min.css", "lib/html-to-image.js"],
      "matches": ["<all_urls>"]
    }
  ]
}


